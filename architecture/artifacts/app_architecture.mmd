  C_RVE -. realizes .-> S_REASON
  C_RVE -. realizes .-> S_VALIDATE
  C_RVE -. realizes .-> S_CQTEST
  C_KGS -. realizes .-> S_STORE
  C_KGS -. realizes .-> S_SPARQL
  C_REPO -. realizes .-> S_VERSION
  C_VIZ -. realizes .-> S_VIZ
  C_DOC -. realizes .-> S_DOCS
  C_FUND -. realizes .-> S_FUND
  C_SKILL -. realizes .-> S_SKILL
  S_AUTH --> |serves| T_DA_2
  S_IMPORT --> |serves| T_DA_3
  S_VOCAB --> |serves| T_DA_6
  S_GLOSS --> |serves| B_SE_4
  S_REASON --> |serves| T_RI_1
  S_VALIDATE --> |serves| T_QV_1
  S_CQTEST --> |serves| T_QV_2
  S_STORE --> |serves| T_OO_1
  S_SPARQL --> |serves| T_AC_1
  S_VERSION --> |serves| T_OO_2
  S_VIZ --> |serves| T_AC_2
  S_DOCS --> |serves| T_AC_3
  S_FUND --> |serves| B_SG_4
  S_SKILL --> |serves| B_CT_1
  C_AUTH -.->|writes| D_ONT
  D_VOC -.->|read by| C_AUTH
  D_GLO -.->|read by| C_AUTH
  C_VOCAB -.->|writes| D_VOC
  C_GLOSS -.->|writes| D_GLO
  D_VOC -.->|read by| C_GLOSS
  C_RVE -.->|writes| D_SHP
  C_RVE -.->|writes| D_CQ
  C_RVE -.->|writes| D_INF
  D_ONT -.->|read by| C_RVE
  D_GRAPH -.->|read by| C_RVE
  C_KGS -.->|writes| D_GRAPH
  C_KGS -.->|writes| D_QRY
  D_ONT -.->|read by| C_KGS
  C_REPO -.->|writes| D_REL
  D_ONT -.->|read by| C_REPO
  D_GRAPH -.->|read by| C_VIZ
  D_ONT -.->|read by| C_VIZ
  C_DOC -.->|writes| D_DOC
  D_ONT -.->|read by| C_DOC
  C_FUND -.->|writes| D_FUND
  C_SKILL -.->|writes| D_SKILL
