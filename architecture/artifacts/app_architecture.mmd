  classDef svc fill:#CFE8FB,stroke:#2E6CA4,color:#000;
  classDef cmp fill:#BBD7F0,stroke:#1F5C95,color:#000;
  classDef dat fill:#E3F0FB,stroke:#3A6EA5,color:#000;
  subgraph CAPS["Capabilities (L2 — Extensible Platform)"]
    B_CT_1["B.CT.1 Skills & Talent Management"]:::cap
    B_SE_4["B.SE.4 Business Glossary & Terminology Management"]:::cap
    B_SG_4["B.SG.4 Funding & Investment Management"]:::cap
    T_AC_1["T.AC.1 Search & Query (SPARQL)"]:::cap
    T_AC_2["T.AC.2 Visualization & Exploration"]:::cap
    T_AC_3["T.AC.3 Documentation & Publishing"]:::cap
    T_DA_2["T.DA.2 Ontology Formalization (OWL/RDFS/SKOS)"]:::cap
    T_DA_3["T.DA.3 Foundational / Top-down Ontology Reuse"]:::cap
    T_DA_6["T.DA.6 Vocabulary & Controlled-Term Management"]:::cap
    T_OO_1["T.OO.1 Triplestore & Ontology Storage"]:::cap
    T_OO_2["T.OO.2 Versioning & Release Management"]:::cap
    T_QV_1["T.QV.1 Ontology Validation (SHACL/constraints)"]:::cap
    T_QV_2["T.QV.2 Ontology Testing (Competency-Question tests)"]:::cap
