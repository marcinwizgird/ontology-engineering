    D_GLO[("D.GLO Business Glossary")]:::dat
    D_SHP[("D.SHP SHACL Shapes")]:::dat
    D_CQ[("D.CQ Competency-Question Test Suite")]:::dat
    D_GRAPH[("D.GRAPH RDF Graph (Triples)")]:::dat
    D_INF[("D.INF Inference Result")]:::dat
    D_REL[("D.REL Ontology Release / Version")]:::dat
    D_QRY[("D.QRY SPARQL Query / Result")]:::dat
    D_DOC[("D.DOC Documentation Site")]:::dat
    D_FUND[("D.FUND Funding / Portfolio Record")]:::dat
    D_SKILL[("D.SKILL Skills Profile")]:::dat
  end
  %% realization (component -> service) and serving (service -> capability)
  C_AUTH -. realizes .-> S_AUTH
  C_AUTH -. realizes .-> S_IMPORT
  C_VOCAB -. realizes .-> S_VOCAB
