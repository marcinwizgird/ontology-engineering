<?xml version="1.0" encoding="UTF-8"?>
<!--
  Foundational (imported) ontology for the LPG converter demo.
  Ontology IRI: http://example.org/foundational
  Referenced by root_ontology.rdf via owl:imports.
-->
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xmlns:found="http://example.org/foundational#">

    <owl:Ontology rdf:about="http://example.org/foundational">
        <rdfs:label>Foundational Ontology</rdfs:label>
    </owl:Ontology>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.org/foundational#Agent">
        <rdfs:label>Agent</rdfs:label>
        <skos:definition>Something that can act, such as a person or an organization.</skos:definition>
        <rdfs:isDefinedBy rdf:resource="http://example.org/foundational"/>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/foundational#Organization">
        <rdfs:label>Organization</rdfs:label>
        <skos:definition>A social or legal entity composed of one or more people.</skos:definition>
        <rdfs:subClassOf rdf:resource="http://example.org/foundational#Agent"/>
        <rdfs:isDefinedBy rdf:resource="http://example.org/foundational"/>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/foundational#Person">
        <rdfs:label>Person</rdfs:label>
        <skos:definition>A human being.</skos:definition>
        <rdfs:subClassOf rdf:resource="http://example.org/foundational#Agent"/>
        <rdfs:isDefinedBy rdf:resource="http://example.org/foundational"/>
    </owl:Class>

    <!-- Object property -->
    <owl:ObjectProperty rdf:about="http://example.org/foundational#hasMember">
        <rdfs:label>has member</rdfs:label>
        <skos:definition>Relates an organization to a person that belongs to it.</skos:definition>
        <rdfs:domain rdf:resource="http://example.org/foundational#Organization"/>
        <rdfs:range rdf:resource="http://example.org/foundational#Person"/>
        <rdfs:isDefinedBy rdf:resource="http://example.org/foundational"/>
    </owl:ObjectProperty>

    <!-- Annotation property -->
    <owl:AnnotationProperty rdf:about="http://example.org/foundational#note">
        <rdfs:label>note</rdfs:label>
        <rdfs:isDefinedBy rdf:resource="http://example.org/foundational"/>
    </owl:AnnotationProperty>

</rdf:RDF>
