{
  "catalog": [
    {
      "id": "P1",
      "name": "ancestry_derivation",
      "persistence": "MATERIALISE",
      "intent": "Derive the full FIBO inheritance chain for every mapped HBIM concept."
    },
    {
      "id": "P2",
      "name": "correct_parent_existing",
      "persistence": "PROPOSE",
      "intent": "Use FIBO to find the correct (most specific) parent for existing HBIM concepts."
    },
    {
      "id": "P3",
      "name": "missing_intermediate_concepts",
      "persistence": "PROPOSE",
      "intent": "Surface FIBO classes that sit between mapped HBIM concepts but have no HBIM twin."
    },
    {
      "id": "P4",
      "name": "missing_narrower_concepts",
      "persistence": "PROPOSE",
      "intent": "Surface FIBO subclasses of mapped concepts that HBIM does not cover."
    },
    {
      "id": "P5",
      "name": "missing_object_properties",
      "persistence": "PROPOSE",
      "intent": "Surface object properties (relationships) FIBO attaches to mapped classes."
    },
    {
      "id": "P6",
      "name": "missing_data_properties",
      "persistence": "PROPOSE",
      "intent": "Surface datatype properties (attributes) FIBO attaches to mapped classes."
    },
    {
      "id": "P7",
      "name": "parent_assignment_candidates",
      "persistence": "PROPOSE",
      "intent": "Assign each discovered concept its correct HBIM parent / re-parent existing ones."
    },
    {
      "id": "P8",
      "name": "parent_validation",
      "persistence": "REPORT",
      "intent": "Use FIBO disjointness to reject impossible parent assignments."
    }
  ],
