# Copy to .env and adjust. All values are optional — the defaults below are what
# docker-compose.yml uses if no .env exists.
#
#   cp .env.example .env        (bash)
#   Copy-Item .env.example .env (PowerShell)

# RESP (Redis wire protocol) port for the FalkorDB endpoint. Bound to 127.0.0.1 only.
FALKORDB_PORT=6379

# FalkorDB Browser UI port (http://localhost:3000). Bound to 127.0.0.1 only.
FALKORDB_BROWSER_PORT=3000

# Extra Redis server arguments. Empty = no auth; fine because the port is
# loopback-only. To require a password: FALKORDB_ARGS=--requirepass changeme
FALKORDB_ARGS=

# Password the converter's client should send. Must match --requirepass above.
# Empty = no auth.
FALKORDB_PASSWORD=

# Default graph (key) the converter writes the LPG into.
FALKORDB_GRAPH=ontology
