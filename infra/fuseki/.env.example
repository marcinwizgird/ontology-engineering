# Copy to .env and adjust. All values are optional — the defaults below are what
# docker-compose.yml uses if no .env exists.
#
#   cp .env.example .env        (bash)
#   Copy-Item .env.example .env (PowerShell)

# Host port for the Fuseki UI / SPARQL endpoints. Bound to 127.0.0.1 only.
FUSEKI_PORT=3030

# Admin password for the web UI (user: admin) and /$/ endpoints.
# Dev-grade default; fine because the port is loopback-only. Change it if you
# ever alter the port binding in docker-compose.yml.
FUSEKI_ADMIN_PASSWORD=admin

# JVM heap. Raise for large loads (all of FIBO wants 4g+). The container needs
# memory beyond this for TDB2's memory-mapped files.
FUSEKI_JVM_ARGS=-Xmx2g
